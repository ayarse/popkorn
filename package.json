{
  "name": "popcorn",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter @popcorn/demo dev",
    "build": "bun --filter @popcorn/demo build",
    "build:grammar": "bun --filter tree-sitter-popcorn build",
    "test:grammar": "bun --filter tree-sitter-popcorn test"
  }
}
