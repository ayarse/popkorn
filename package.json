{
  "name": "popkorn",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "bun --filter @popkorn/playground dev",
    "build": "bun --filter @popkorn/playground build",
    "test": "bun --filter @popkorn/parser --filter @popkorn/player --filter @popkorn/react-native --filter @popkorn/converters test && bun test tools/",
    "build:packages": "bun --filter @popkorn/parser --filter @popkorn/player --filter @popkorn/react-native --filter @popkorn/converters build",
    "changeset": "changeset",
    "version-packages": "changeset version && bun install",
    "release": "bun run build:packages && bun scripts/publish.ts",
    "lint": "biome check",
    "format": "biome check --write",
    "typecheck": "bun --filter @popkorn/parser --filter @popkorn/player --filter @popkorn/playground --filter @popkorn/converters typecheck",
    "convert": "./packages/popkorn-converters/src/cli.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@changesets/cli": "^2.31.0",
    "typescript": "~5.6.2"
  },
  "//": "Single @types/react across the workspace: playground + react-native (and skia's <19 peer) want 18; only expo-demo asked for 19, which leaks into playground's tsc via bun hoisting. Pin 18 so the build is hoist-order-independent.",
  "overrides": {
    "@types/react": "18.3.27"
  }
}
