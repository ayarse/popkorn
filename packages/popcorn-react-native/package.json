{
  "name": "@popcorn/react-native",
  "description": "React Native Skia renderer backend for the Popcorn player",
  "license": "MIT",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@popcorn/player": "workspace:*"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "@shopify/react-native-skia": "*"
  },
  "devDependencies": {
    "@popcorn/config": "workspace:*",
    "@shopify/react-native-skia": "^1.0.0",
    "@types/react": "^18.0.0",
    "typescript": "~5.6.2"
  }
}
