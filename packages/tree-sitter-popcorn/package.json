{
  "name": "tree-sitter-popcorn",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for Popcorn DSL",
  "keywords": [
    "tree-sitter",
    "parser",
    "popcorn"
  ],
  "files": [
    "grammar.js",
    "src/**",
    "*.wasm"
  ],
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "build:wasm": "tree-sitter build --wasm",
    "copy:wasm": "cp tree-sitter-popcorn.wasm ../popcorn-parser/wasm/",
    "build": "bun run generate && bun run build:wasm && bun run copy:wasm",
    "parse": "tree-sitter parse"
  }
}
