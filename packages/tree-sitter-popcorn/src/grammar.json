{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "popcorn",
  "word": "identifier",
  "rules": {
    "stylesheet": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_item"
      }
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "rule"
        },
        {
          "type": "SYMBOL",
          "name": "keyframes_rule"
        }
      ]
    },
    "rule": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "selector"
        },
        {
          "type": "SYMBOL",
          "name": "block"
        }
      ]
    },
    "selector": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "id_selector"
        },
        {
          "type": "SYMBOL",
          "name": "class_selector"
        },
        {
          "type": "SYMBOL",
          "name": "canvas_selector"
        },
        {
          "type": "SYMBOL",
          "name": "root_selector"
        }
      ]
    },
    "id_selector": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "class_selector": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "."
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "canvas_selector": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "STRING",
          "value": "canvas"
        }
      ]
    },
    "root_selector": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "STRING",
          "value": "root"
        }
      ]
    },
    "block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_block_item"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_block_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "declaration"
        },
        {
          "type": "SYMBOL",
          "name": "child_rule"
        },
        {
          "type": "SYMBOL",
          "name": "pseudo_rule"
        }
      ]
    },
    "pseudo_rule": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "&"
        },
        {
          "type": "SYMBOL",
          "name": "pseudo_selector"
        },
        {
          "type": "SYMBOL",
          "name": "declaration_block"
        }
      ]
    },
    "pseudo_selector": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "hover_pseudo"
        },
        {
          "type": "SYMBOL",
          "name": "active_pseudo"
        }
      ]
    },
    "hover_pseudo": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "STRING",
          "value": "hover"
        }
      ]
    },
    "active_pseudo": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "STRING",
          "value": "active"
        }
      ]
    },
    "child_rule": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ">"
        },
        {
          "type": "SYMBOL",
          "name": "rule"
        }
      ]
    },
    "declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "property"
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "SYMBOL",
          "name": "_value_list"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": ";"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "property": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "custom_property"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "custom_property": {
      "type": "PATTERN",
      "value": "--[a-zA-Z_][a-zA-Z0-9_\\-]*"
    },
    "_value_list": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "SYMBOL",
          "name": "_value"
        }
      }
    },
    "_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "dimension"
        },
        {
          "type": "SYMBOL",
          "name": "percentage"
        },
        {
          "type": "SYMBOL",
          "name": "color"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "var_function"
        },
        {
          "type": "SYMBOL",
          "name": "function_call"
        },
        {
          "type": "SYMBOL",
          "name": "keyword"
        }
      ]
    },
    "var_function": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "var"
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "SYMBOL",
          "name": "custom_property"
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "number": {
      "type": "PATTERN",
      "value": "\\-?[0-9]+(\\.[0-9]+)?"
    },
    "dimension": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\-?[0-9]+(\\.[0-9]+)?"
        },
        {
          "type": "SYMBOL",
          "name": "unit"
        }
      ]
    },
    "unit": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "px"
        },
        {
          "type": "STRING",
          "value": "deg"
        },
        {
          "type": "STRING",
          "value": "em"
        },
        {
          "type": "STRING",
          "value": "rem"
        },
        {
          "type": "STRING",
          "value": "s"
        },
        {
          "type": "STRING",
          "value": "ms"
        },
        {
          "type": "STRING",
          "value": "%"
        }
      ]
    },
    "percentage": {
      "type": "PATTERN",
      "value": "\\-?[0-9]+(\\.[0-9]+)?%"
    },
    "color": {
      "type": "PATTERN",
      "value": "#[0-9a-fA-F]{3,8}"
    },
    "string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "PATTERN",
              "value": "[^\"]*"
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "'"
            },
            {
              "type": "PATTERN",
              "value": "[^']*"
            },
            {
              "type": "STRING",
              "value": "'"
            }
          ]
        }
      ]
    },
    "function_call": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "arguments"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "arguments": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_value_list"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "_value_list"
              }
            ]
          }
        }
      ]
    },
    "keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "member_expression"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "member_expression": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "STRING",
          "value": "."
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "keyframes_rule": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "@keyframes"
        },
        {
          "type": "SYMBOL",
          "name": "keyframes_name"
        },
        {
          "type": "SYMBOL",
          "name": "keyframes_block"
        }
      ]
    },
    "keyframes_name": {
      "type": "SYMBOL",
      "name": "identifier"
    },
    "keyframes_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "keyframe"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "keyframe": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "keyframe_selector_list"
        },
        {
          "type": "SYMBOL",
          "name": "declaration_block"
        }
      ]
    },
    "keyframe_selector_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_keyframe_selector"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "_keyframe_selector"
              }
            ]
          }
        }
      ]
    },
    "_keyframe_selector": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "from"
        },
        {
          "type": "STRING",
          "value": "to"
        },
        {
          "type": "SYMBOL",
          "name": "percentage"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        }
      ]
    },
    "declaration_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "declaration"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_\\-]*"
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "/*"
        },
        {
          "type": "PATTERN",
          "value": "[^*]*\\*+([^/*][^*]*\\*+)*"
        },
        {
          "type": "STRING",
          "value": "/"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s+"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}