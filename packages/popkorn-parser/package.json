{
  "name": "@popkorn/parser",
  "version": "0.1.0",
  "description": "Parser for the Popkorn DSL",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "bin": {
      "popkorn-minify": "./dist/minify-cli.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@popkorn/config": "workspace:*",
    "@types/node": "^22"
  },
  "bin": {
    "popkorn-minify": "./src/minify-cli.ts"
  }
}
