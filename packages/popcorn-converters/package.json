{
  "name": "@popcorn/converters",
  "version": "0.1.0",
  "description": "Lottie and SVG converters for the Popcorn DSL",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "popcorn-convert": "./src/cli.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "bin": {
      "popcorn-convert": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@popcorn/parser": "workspace:*",
    "@popcorn/player": "workspace:*"
  },
  "devDependencies": {
    "@popcorn/config": "workspace:*",
    "@types/node": "^22"
  }
}
